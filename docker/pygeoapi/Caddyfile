http://:5000 {
    # Honest health check: Fly.io holds edge traffic until Python is genuinely ready.
    handle /health {
        # Gateway-only mode has no Python backend; Caddy itself is the service.
        @gatewayOnly expression `"{$DEPLOY_PYGEOAPI}" == "0"`
        respond @gatewayOnly "OK" 200

        # Full mode: no lb_try_duration so this probe returns 502 immediately
        # when Gunicorn isn't up — Fly.io sees the failure and holds traffic.
        reverse_proxy localhost:5001 {
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }

    # --- Main Application Logic ---
    handle {
        # Private deployment guard: If IS_PRIVATE=1, require X-API-Key header
        # matching one of the active keys. CADDY_API_KEYS_REGEX is a "|"-joined
        # alternation of hex keys (e.g. "abc123|def456"); empty = reject all.
        @isPrivate expression `"{$IS_PRIVATE}" == "1"`
        @missingKey {
            match @isPrivate
            not header X-API-Key *
        }
        @wrongKey {
            match @isPrivate
            header X-API-Key *
            not header_regexp X-API-Key ^({$CADDY_API_KEYS_REGEX})$
        }
        respond @missingKey "Unauthorized" 401
        respond @wrongKey "Unauthorized" 401

        # Private deployments must never be cached by Cloudflare or any CDN.
        # Overrides pygeoapi's own Cache-Control header on the way out.
        @private expression `"{$IS_PRIVATE}" == "1"`
        header @private Cache-Control "no-store"

        # WMS via QGIS Server (only if DEPLOY_QGIS=1)
        @hasQgis expression `"{$DEPLOY_QGIS}" == "1"`
        handle /ows/* {
            route @hasQgis {
                reverse_proxy {$QGIS_UPSTREAM_TARGET:qgis-server:80} {
                    header_up Host {upstream_hostport}
                    header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
                    header_up -X-Forwarded-Ssl
                    header_up -X-Forwarded-Protocol
                    header_up -X-Scheme
                }
            }
            respond 404
        }

        # OGC API via pygeoapi (only if DEPLOY_PYGEOAPI=1)
        @hasPygeoapi expression `"{$DEPLOY_PYGEOAPI}" == "1"`
        handle {
            route @hasPygeoapi {
                reverse_proxy localhost:5001 {
                    # Restore "Loading" behavior: wait for pygeoapi to finish booting
                    lb_try_duration 60s
                    lb_try_interval 1s

                    header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
                    header_up -X-Forwarded-Ssl
                    header_up -X-Forwarded-Protocol
                    header_up -X-Scheme
                }
            }
            respond 404
        }
    }
}
