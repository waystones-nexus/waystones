# GitHub OAuth Configuration
# Copy this file to .env and fill in your values

# Frontend (baked into bundle at build time)
VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_REDIRECT_URI=http://localhost:3000/oauth-callback.html

# Server-side only (never exposed to browser)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI features
GEMINI_API_KEY=
VITE_DEFAULT_AI_KEY=
VITE_DEFAULT_AI_PROVIDER=gemini

# Production only (set in Railway dashboard)
# APP_ORIGIN=https://your-app.up.railway.app
# VITE_GITHUB_REDIRECT_URI=https://your-app.up.railway.app/oauth-callback.html
